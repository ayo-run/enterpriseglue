NODE_ENV=development

# Backend
API_PORT=8787
# Used only when EXPOSE_BACKEND=true
BACKEND_HOST_PORT=8787
# Toggle backend host exposure in Docker dev.
# - true: backend reachable directly on BACKEND_HOST_PORT (e.g. http://localhost:8787)
# - false: backend internal-only; use frontend origin + proxied API paths
EXPOSE_BACKEND=true

# Frontend (Nginx in Docker dev/prod)
FRONTEND_HOST_PORT=5173
# Optional: override the Nginx upstream host used by the frontend container.
# Default is the Docker service name + API port (backend:8787).
API_UPSTREAM=backend:8787

# Database Configuration
# Supported: postgres, oracle, mssql, spanner, mysql
# Docker dev environment uses PostgreSQL by default
# For other databases, see backend/.env.example for configuration options
DATABASE_TYPE=postgres
# Keep FRONTEND_URL in sync with FRONTEND_HOST_PORT.
FRONTEND_URL=http://localhost:5173

POSTGRES_SCHEMA=main

# Postgres (used by both db container and backend)
POSTGRES_USER=enterpriseglue
POSTGRES_PASSWORD=enterpriseglue
POSTGRES_DB=enterpriseglue
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DATABASE=enterpriseglue
POSTGRES_SSL=false
# Controls TLS certificate verification for PostgreSQL connections.
# - 'true'  = verify the server certificate (recommended for production)
# - 'false' = skip certificate verification (ok for Docker-internal connections)
# When using 'true' with Cloud SQL or external DBs, provide the CA cert:
#   NODE_EXTRA_CA_CERTS=/app/certs/server-ca.pem
# Or on Node 22+: NODE_OPTIONS="--use-system-ca"
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_HOST_PORT=5432

# Auth (dev-only defaults)
JWT_SECRET=dev_jwt_secret_change_me_please_32_chars
ADMIN_EMAIL=admin@enterpriseglue.ai
ADMIN_PASSWORD=dev_admin_password_change_me
# Set to true when you want the seeded admin (created by ADMIN_EMAIL on first run)
# to bypass email verification. Useful for self-hosted/local installs.
# ADMIN_EMAIL_VERIFICATION_EXEMPT=true

# Git + encryption (dev-only defaults)
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Email Bootstrap (First Run)
# Optional: Set these to seed the default email configuration during deploy/startup.
# EMAIL_PROVIDER, EMAIL_API_KEY, EMAIL_FROM_NAME, EMAIL_FROM_EMAIL
# EMAIL_CONFIG_NAME, EMAIL_REPLY_TO, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
# EMAIL_SMTP_SECURE, EMAIL_SMTP_USER
# Supported providers: resend, sendgrid, mailgun, mailjet, smtp
EMAIL_CONFIG_NAME="Default Email Configuration"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace-with-provider-api-key
EMAIL_FROM_NAME=EnterpriseGlue
EMAIL_FROM_EMAIL=noreply@example.com
# EMAIL_REPLY_TO=support@example.com
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=

# Frontend
# Compose maps API_BASE_URL to VITE_API_BASE_URL inside the frontend container.
# Recommended for Docker: leave empty to use same-origin API paths through Nginx proxy.
# Set only when frontend must call a different API origin.
API_BASE_URL=
VITE_FEATURE_VOYAGER=true
VITE_FEATURE_STARBASE=true
VITE_FEATURE_MISSION_CONTROL=true
VITE_FEATURE_ENGINES=true
VITE_FEATURE_MC_PROCESSES=true
VITE_FEATURE_MC_BATCHES=true
VITE_FEATURE_MC_DECISIONS=true
VITE_FEATURE_SB_PROJECTS=true
VITE_FEATURE_SB_FILES=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_USER_MENU=true
