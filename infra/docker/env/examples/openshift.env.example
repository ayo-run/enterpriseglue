# OpenShift target
OPENSHIFT_NAMESPACE=enterpriseglue
OPENSHIFT_ROUTE_HOST=enterpriseglue.example.com

# Published image refs (must include tag)
BACKEND_IMAGE=ghcr.io/OWNER/enterpriseglue-the-bridge-oss-backend:v0.1.0
FRONTEND_IMAGE=ghcr.io/OWNER/enterpriseglue-the-bridge-oss-frontend:v0.1.0

# Optional: if set, script will create/update ghcr-pull-secret
GHCR_USERNAME=github-username
GHCR_TOKEN=ghp_xxx
REGISTRY_SERVER=ghcr.io

# Runtime secrets
JWT_SECRET=replace-with-random-secret
ADMIN_EMAIL=admin@enterpriseglue.ai
ADMIN_PASSWORD=replace-with-strong-password
ENCRYPTION_KEY=replace-with-64-hex-characters

# Email Bootstrap (First Run)
# Optional: Set these to seed the default email configuration during deploy/startup.
# EMAIL_PROVIDER, EMAIL_API_KEY, EMAIL_FROM_NAME, EMAIL_FROM_EMAIL
# EMAIL_CONFIG_NAME, EMAIL_REPLY_TO, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
# EMAIL_SMTP_SECURE, EMAIL_SMTP_USER
# Supported providers: resend, sendgrid, mailgun, mailjet, smtp
EMAIL_CONFIG_NAME="Default Email Configuration"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace-with-provider-api-key
EMAIL_FROM_NAME=EnterpriseGlue
EMAIL_FROM_EMAIL=noreply@example.com
# EMAIL_REPLY_TO=support@example.com
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=

# Database mode
DATABASE_TYPE=postgres

# -----------------------------------------------------------------------------
# Postgres — Option A: connection string (recommended for managed/external DBs)
# Supports standard PostgreSQL URL format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA&sslmode=require
#
# Production with two hosts (primary + replica via load balancer / pgBouncer):
#   Point POSTGRES_URL at your single service endpoint (pgBouncer, HAProxy,
#   cloud load balancer, or Patroni primary service). The backend uses a single
#   write-path connection — read/write split is handled at the infrastructure
#   level, not in the application.
#
# Examples:
#   AWS RDS (single endpoint):    postgresql://user:pass@mydb.xyz.rds.amazonaws.com:5432/enterpriseglue?schema=main&sslmode=require
#   Azure Database for Postgres:  postgresql://user%40server:pass@server.postgres.database.azure.com:5432/enterpriseglue?schema=main&sslmode=require
#   OpenShift pgBouncer service:  postgresql://user:pass@pgbouncer.db-svc:5432/enterpriseglue?schema=main
# POSTGRES_URL=postgresql://enterpriseglue:replace-postgres-password@postgresql:5432/enterpriseglue?schema=main

# Postgres — Option B: individual variables (in-cluster PostgreSQL)
# Use when deploying the bundled PostgreSQL service inside OpenShift.
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DATABASE=enterpriseglue
POSTGRES_SCHEMA=main
POSTGRES_USER=enterpriseglue
POSTGRES_PASSWORD=replace-postgres-password

# Postgres SSL (applies to both Option A and B for external DBs)
# Set POSTGRES_SSL=true and POSTGRES_SSL_REJECT_UNAUTHORIZED=true for production
# managed DB services (RDS, Azure, Cloud SQL, etc.).
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Oracle settings (required when DATABASE_TYPE=oracle)
#
# Option A: connection string — required for multi-host HA/failover setups.
# Supports Oracle Easy Connect Plus and full TNS descriptors.
# ORACLE_USER and ORACLE_PASSWORD are required in all Oracle modes,
# including when ORACLE_CONNECTION_STRING is set.
#
# Easy Connect Plus (two hosts, automatic failover):
#   ORACLE_CONNECTION_STRING=host1.example.com:1521,host2.example.com:1521/myservice
#
# TNS descriptor (explicit failover + load balancing):
#   ORACLE_CONNECTION_STRING=(DESCRIPTION=(FAILOVER=on)(LOAD_BALANCE=on)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=host1.example.com)(PORT=1521))(ADDRESS=(PROTOCOL=TCP)(HOST=host2.example.com)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=myservice)))
#
# ORACLE_CONNECTION_STRING=host1.example.com:1521,host2.example.com:1521/XEPDB1
ORACLE_USER=enterpriseglue
ORACLE_PASSWORD=replace-oracle-password

# Option B: single-host connection details (used when ORACLE_CONNECTION_STRING is empty)
ORACLE_HOST=oracle-db
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_SCHEMA=ENTERPRISEGLUE

# Optional
GIT_DEFAULT_BRANCH=main
SKIP_EXTERNAL_HEALTHCHECK=false
