# Use 'production' for self-hosting. HTTP engine URLs are automatically allowed
# for localhost, private IPs (10.x, 172.16-31.x, 192.168.x), Docker service
# names, and host.docker.internal — no need to switch to 'development'.
NODE_ENV=production

# -----------------------------------------------------------------------------
# Image references
# GHCR (default, always published):
BACKEND_IMAGE=ghcr.io/enterpriseglue/enterpriseglue-the-bridge-oss-backend
FRONTEND_IMAGE=ghcr.io/enterpriseglue/enterpriseglue-the-bridge-oss-frontend
# Docker Hub alternative (also published):
# BACKEND_IMAGE=docker.io/enterpriseglue/enterpriseglue-the-bridge-oss-backend
# FRONTEND_IMAGE=docker.io/enterpriseglue/enterpriseglue-the-bridge-oss-frontend
# Use 'latest' for the most recent release, or pin to a specific version e.g. v1.2.3
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Ports
FRONTEND_HOST_PORT=8080
FRONTEND_URL=http://localhost:8080
API_PORT=8787

# -----------------------------------------------------------------------------
# Database (Postgres — included in the compose file)
DATABASE_TYPE=postgres
POSTGRES_SCHEMA=main
POSTGRES_USER=enterpriseglue
# Generate: openssl rand -base64 16
POSTGRES_PASSWORD=change_me
POSTGRES_DB=enterpriseglue
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DATABASE=enterpriseglue
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# -----------------------------------------------------------------------------
# Auth — CHANGE ALL THREE BEFORE FIRST RUN
# Generate JWT_SECRET:      openssl rand -hex 32
JWT_SECRET=change_me_change_me_change_me_change_me
ADMIN_EMAIL=admin@example.com
# Generate ADMIN_PASSWORD:  openssl rand -base64 16
ADMIN_PASSWORD=change_me_change_me
# Set to true when you want the seeded admin (created by ADMIN_EMAIL on first run)
# to bypass email verification. Useful for self-hosted/local installs.
# ADMIN_EMAIL_VERIFICATION_EXEMPT=true

# Email Bootstrap (First Run)
# Optional: Set these to seed the default email configuration during deploy/startup.
# EMAIL_PROVIDER, EMAIL_API_KEY, EMAIL_FROM_NAME, EMAIL_FROM_EMAIL
# EMAIL_CONFIG_NAME, EMAIL_REPLY_TO, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
# EMAIL_SMTP_SECURE, EMAIL_SMTP_USER
# Supported providers: resend, sendgrid, mailgun, mailjet, smtp
EMAIL_CONFIG_NAME="Default Email Configuration"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace-with-provider-api-key
EMAIL_FROM_NAME=EnterpriseGlue
EMAIL_FROM_EMAIL=noreply@example.com
# EMAIL_REPLY_TO=support@example.com
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=

# -----------------------------------------------------------------------------
# Encryption — CHANGE BEFORE FIRST RUN (losing this key means losing encrypted data)
# Generate ENCRYPTION_KEY:  openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# -----------------------------------------------------------------------------
# Git
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main

# -----------------------------------------------------------------------------
# Frontend
# Keep empty for same-origin API calls through the Nginx reverse proxy (recommended).
# Set only when the frontend must reach a different API origin.
API_BASE_URL=
