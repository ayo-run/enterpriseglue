# Use 'production' for deployed environments. HTTP engine URLs are automatically
# allowed for localhost, private IPs, Docker service names, and host.docker.internal.
NODE_ENV=production

# Backend
# Backend remains internal-only in Docker production compose (no host port publish by default).
API_PORT=8787
FRONTEND_HOST_PORT=8080
# Keep FRONTEND_URL in sync with FRONTEND_HOST_PORT.
FRONTEND_URL=http://localhost:8080

# Database Configuration
DATABASE_TYPE=postgres
POSTGRES_SCHEMA=main

# Postgres (used by both db container and backend)
POSTGRES_USER=enterpriseglue
POSTGRES_PASSWORD=change_me
POSTGRES_DB=enterpriseglue
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DATABASE=enterpriseglue
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# Auth (set strong secrets in production)
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=change_me_change_me_change_me_change_me
ADMIN_EMAIL=admin@enterpriseglue.ai
# Generate ADMIN_PASSWORD: openssl rand -base64 16
ADMIN_PASSWORD=change_me_change_me
# Set to true only if you want the seeded admin (created on first run)
# to bypass email verification.
# ADMIN_EMAIL_VERIFICATION_EXEMPT=false

# Email Bootstrap (First Run)
# Optional: Set these to seed the default email configuration during deploy/startup.
# EMAIL_PROVIDER, EMAIL_API_KEY, EMAIL_FROM_NAME, EMAIL_FROM_EMAIL
# EMAIL_CONFIG_NAME, EMAIL_REPLY_TO, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
# EMAIL_SMTP_SECURE, EMAIL_SMTP_USER
# Supported providers: resend, sendgrid, mailgun, mailjet, smtp
EMAIL_CONFIG_NAME="Default Email Configuration"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace-with-provider-api-key
EMAIL_FROM_NAME=EnterpriseGlue
EMAIL_FROM_EMAIL=noreply@example.com
# EMAIL_REPLY_TO=support@example.com
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=

# Git + encryption (set strong key in production)
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main
# Generate ENCRYPTION_KEY: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Frontend build
# Keep empty for same-origin API calls through Nginx reverse proxy (recommended).
# Set only when frontend must call a different API origin.
API_BASE_URL=
