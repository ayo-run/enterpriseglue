# =============================================================================
# EnterpriseGlue Backend Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Server Configuration
API_PORT=8787

# =============================================================================
# Database Configuration
# =============================================================================
# Supported: postgres, oracle, mssql, spanner, mysql
DATABASE_TYPE=postgres

# =============================================================================
# PostgreSQL Configuration (when DATABASE_TYPE=postgres)
# =============================================================================
# Works with: PostgreSQL, Amazon RDS for PostgreSQL, Amazon Aurora PostgreSQL
#
# Option A: connection string (recommended for managed/external/multi-host DBs)
# Supports standard PostgreSQL URL format including sslmode query param.
# When set, individual vars below (POSTGRES_HOST etc.) are not required.
# POSTGRES_URL=postgresql://user:password@host:5432/enterpriseglue?schema=main&sslmode=require

# Option B: individual variables
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DATABASE=postgres
POSTGRES_SCHEMA=main
POSTGRES_SSL=true
# Required. Controls TLS certificate verification for PostgreSQL connections.
# - 'true'  = verify the server certificate (recommended for production)
# - 'false' = skip certificate verification (encrypted but no identity check)
# If set to 'true' and connecting to Cloud SQL / self-signed certs, you must
# provide the CA certificate via NODE_EXTRA_CA_CERTS (see below).
POSTGRES_SSL_REJECT_UNAUTHORIZED=true

# Path to a PEM file containing the CA certificate for your database server.
# Required when POSTGRES_SSL_REJECT_UNAUTHORIZED=true and the CA is not in your
# system trust store.
#
# For Google Cloud SQL:
#   gcloud sql instances describe <INSTANCE> --format="value(serverCaCert.cert)" > server-ca.pem
#
# For other providers: download the CA bundle from your provider's docs.
#
# Alternatively, on Node 22+ you can use NODE_OPTIONS="--use-system-ca" if the
# CA is already in your OS trust store (e.g. macOS Keychain).
# NODE_EXTRA_CA_CERTS=./server-ca.pem

# =============================================================================
# Oracle Configuration (when DATABASE_TYPE=oracle)
# =============================================================================
# Option A: connection string — required for multi-host HA/failover setups.
# Supports Oracle Easy Connect Plus and full TNS descriptors.
# When set, ORACLE_HOST/PORT/SERVICE_NAME/SID are not required.
#
# Easy Connect Plus (two hosts):
#   ORACLE_CONNECTION_STRING=host1.example.com:1521,host2.example.com:1521/MYSERVICE
# TNS descriptor:
#   ORACLE_CONNECTION_STRING=(DESCRIPTION=(FAILOVER=on)(LOAD_BALANCE=on)(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=host1)(PORT=1521))(ADDRESS=(PROTOCOL=TCP)(HOST=host2)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=MYSERVICE)))
#
# ORACLE_CONNECTION_STRING=host1.example.com:1521,host2.example.com:1521/XEPDB1

# Option B: individual variables (single host)
# ORACLE_HOST=your-oracle-host
# ORACLE_PORT=1521
# ORACLE_USER=enterpriseglue
# ORACLE_PASSWORD=your-oracle-password
# ORACLE_SERVICE_NAME=XEPDB1
# ORACLE_SID=XE
# ORACLE_SCHEMA=MAIN
#
# Note: Oracle requires the oracledb npm package and Oracle Instant Client
# Install: pnpm add oracledb
# See: https://oracle.github.io/node-oracledb/INSTALL.html

# =============================================================================
# SQL Server Configuration (when DATABASE_TYPE=mssql)
# =============================================================================
# Works with: SQL Server (on-premises), Azure SQL Database, Azure SQL Managed Instance
#
# MSSQL_HOST=your-sqlserver-host
# MSSQL_PORT=1433
# MSSQL_USER=sa
# MSSQL_PASSWORD=your-sqlserver-password
# MSSQL_DATABASE=enterpriseglue
# MSSQL_SCHEMA=dbo
# MSSQL_ENCRYPT=true
# MSSQL_TRUST_SERVER_CERTIFICATE=false
#
# Azure SQL example:
#   MSSQL_HOST=your-server.database.windows.net
#   MSSQL_ENCRYPT=true (required for Azure)
#   MSSQL_TRUST_SERVER_CERTIFICATE=false
#
# Note: SQL Server requires the mssql npm package
# Install: pnpm add mssql

# =============================================================================
# Google Spanner Configuration (when DATABASE_TYPE=spanner)
# =============================================================================
# SPANNER_PROJECT_ID=your-gcp-project-id
# SPANNER_INSTANCE_ID=your-spanner-instance
# SPANNER_DATABASE_ID=enterpriseglue
#
# Note: Spanner requires @google-cloud/spanner npm package
# Install: pnpm add @google-cloud/spanner
# Set GOOGLE_APPLICATION_CREDENTIALS env var to service account JSON path
# For local emulator, set: SPANNER_EMULATOR_HOST=localhost:9010

# =============================================================================
# MySQL Configuration (when DATABASE_TYPE=mysql)
# =============================================================================
# Works with: MySQL, MariaDB, Amazon RDS for MySQL, Amazon Aurora MySQL
#
# MYSQL_HOST=your-mysql-host
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=enterpriseglue
#
# Note: MySQL requires the mysql2 npm package
# Install: pnpm add mysql2

# =============================================================================
# Authentication Configuration
# =============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-a-secure-random-string-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Admin Bootstrap (First Run)
# Set these to seed the initial admin account on a fresh database.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-secure-password
# Set to true when you want the seeded admin (created by ADMIN_EMAIL on first run)
# to bypass email verification. Useful for self-hosted/local installs.
# ADMIN_EMAIL_VERIFICATION_EXEMPT=true

# =============================================================================
# Email Bootstrap (First Run)
# =============================================================================
# Optional: Set these to seed the default email configuration during deploy/startup.
# EMAIL_PROVIDER, EMAIL_API_KEY, EMAIL_FROM_NAME, EMAIL_FROM_EMAIL
# EMAIL_CONFIG_NAME, EMAIL_REPLY_TO, EMAIL_SMTP_HOST, EMAIL_SMTP_PORT,
# EMAIL_SMTP_SECURE, EMAIL_SMTP_USER
# Supported providers: resend, sendgrid, mailgun, mailjet, smtp
EMAIL_CONFIG_NAME="Default Email Configuration"
EMAIL_PROVIDER=resend
EMAIL_API_KEY=replace-with-provider-api-key
EMAIL_FROM_NAME=EnterpriseGlue
EMAIL_FROM_EMAIL=noreply@example.com
# EMAIL_REPLY_TO=support@example.com
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=

# =============================================================================
# Camunda Configuration (Optional)
# =============================================================================
# CAMUNDA_BASE_URL=http://localhost:8080/engine-rest
# CAMUNDA_USERNAME=demo
# CAMUNDA_PASSWORD=demo

# =============================================================================
# Microsoft Entra ID (Azure AD) Configuration (Optional)
# =============================================================================
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_TENANT_ID=your-tenant-id
# MICROSOFT_REDIRECT_URI=http://localhost:8787/api/auth/microsoft/callback
# Use the public app domain in Entra for production:
#   https://your-enterpriseglue-domain.example/api/auth/microsoft/callback
#
# SAML 2.0 providers (including Microsoft Entra ID as IdP) are configured in
# Platform Settings -> SSO (entityId, ssoUrl, certificate, signatureAlgorithm).
# Callback endpoint for SAML assertions. Keep this global; tenant context is
# preserved through SAML RelayState during login.
#   http://localhost:5173/api/auth/saml/callback
#   https://your-enterpriseglue-domain.example/api/auth/saml/callback

# =============================================================================
# Google OAuth Configuration (Optional)
# =============================================================================
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# =============================================================================
# Frontend & Environment
# =============================================================================
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Proxy Configuration
# Number of proxy hops, 'loopback', or specific subnet (e.g., '10.0.0.0/8')
# TRUST_PROXY=1

# =============================================================================
# Git Versioning Configuration
# =============================================================================
GIT_REPOS_PATH=./data/repos
GIT_DEFAULT_BRANCH=main

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=generate-a-64-char-hex-string

# File Lock Configuration
LOCK_TIMEOUT_MS=1800000
LOCK_HEARTBEAT_INTERVAL_MS=30000

# Push Retry Configuration
PUSH_RETRY_ATTEMPTS=3
PUSH_RETRY_DELAY_MS=5000
